rules_version = '2';
service cloud.firestore {
 match /databases/{database}/documents {
  function signed(){return request.auth != null && request.auth.token.email_verified == true;}
  function member(chatId){return signed() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;}
  match /users/{uid}{allow read:if signed();allow create,update:if signed()&&request.auth.uid==uid;allow delete:if false;}
  match /statuses/{id}{allow read:if signed();allow create:if signed()&&request.resource.data.uid==request.auth.uid&&request.resource.data.text is string&&request.resource.data.text.size()<=500;allow update:if false;allow delete:if signed()&&resource.data.uid==request.auth.uid;}
  match /chats/{chatId}{
   allow read:if signed()&&request.auth.uid in resource.data.members;
   allow create:if signed()&&request.auth.uid in request.resource.data.members&&request.resource.data.members.size()==2;
   allow update:if member(chatId);allow delete:if false;
   match /messages/{id}{allow read:if member(chatId);allow create:if member(chatId)&&request.resource.data.senderId==request.auth.uid&&request.resource.data.text is string&&request.resource.data.text.size()>0&&request.resource.data.text.size()<=1000;allow update:if member(chatId);allow delete:if member(chatId)&&resource.data.senderId==request.auth.uid;}
   match /readState/{uid}{allow read,create,update:if member(chatId);allow delete:if false;}
   match /typing/{uid}{allow read:if member(chatId);allow create,update:if member(chatId)&&request.auth.uid==uid;allow delete:if false;}
  }
 }
}